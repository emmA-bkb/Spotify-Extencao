# Spotify OAuth Credentials
# Obtenha em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui
SPOTIFY_REDIRECT_URI=https://spotify-extencao.onrender.com/auth/spotify/callback

# Flask Security
# Gere uma SECRET_KEY segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cole_uma_chave_segura_aqui

# Flask Debug (NUNCA usar True em produção!)
FLASK_DEBUG=False

# Port (opcional, padrão: 5000)
PORT=5000
